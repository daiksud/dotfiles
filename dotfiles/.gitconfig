[user]
	signingKey = ~/.ssh/id_ed25519.pub
[init]
	defaultBranch = main
[push]
	default = current
	autoSetupRemote = true
[pull]
	rebase = true
[rebase]
	autoSquash = true
[commit]
	gpgsign = true
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
[core]
	quotepath = false
